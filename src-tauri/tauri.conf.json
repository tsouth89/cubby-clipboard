{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Cubby Clipboard",
  "version": "0.1.0",
  "identifier": "ai.southforge.cubbyclipboard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cubby",
        "width": 520,
        "height": 620,
        "minWidth": 420,
        "minHeight": 300,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "center": false,
        "skipTaskbar": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/Cubby Clipboard/images/**",
          "$LOCALDATA/Cubby Clipboard/images/**"
        ]
      },
      "capabilities": [
        "default"
      ]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}
